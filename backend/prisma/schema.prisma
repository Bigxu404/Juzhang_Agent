generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(uuid())
  appleId       String?   @unique
  deviceId      String?   @unique
  personaPrompt String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  password      String
  username      String    @unique
  apiKey        String?
  modelName     String?   @default("MiniMax 2.7")
  subModelName  String?   @default("MiniMax 2.7")
  memories      Memory[]
  sessions      Session[]
  skills        Skill[]
  files         File[]
}

model Session {
  id        String    @id @default(uuid())
  userId    String
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
  files     File[]
  user      User      @relation(fields: [userId], references: [id])
}

model File {
  id        String   @id @default(uuid())
  userId    String
  sessionId String?
  filename  String
  mimeType  String
  localPath String
  url       String
  size      Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  session   Session? @relation(fields: [sessionId], references: [id])
}

model Message {
  id        String   @id @default(uuid())
  sessionId String
  role      String
  content   String
  toolCalls String?
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id])
}

model Memory {
  id        String   @id @default(uuid())
  userId    String
  content   String
  embedding String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Skill {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String
  content     String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}
