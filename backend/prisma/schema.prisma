datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(uuid())
  username      String    @unique // 用于账号密码登录
  password      String    // 哈希后的密码
  appleId       String?   @unique
  deviceId      String?   @unique // 用于访客/匿名登录
  personaPrompt String?   // 夜间反思更新的专属人设
  apiKey        String?   // 用户自己填写的 API Key
  modelName     String?   @default("MiniMax-Text-01") // 用户选择的模型名称
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  memories      Memory[]
  skills        Skill[]   // 用户自定义上传的 Skills
}

model Session {
  id        String    @id @default(uuid())
  userId    String
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  messages  Message[]
}

model Message {
  id        String   @id @default(uuid())
  sessionId String
  role      String   // 'user' | 'assistant' | 'tool' | 'system'
  content   String   // 内容
  toolCalls String?  // JSON string (如果有调用工具)
  createdAt DateTime @default(now())

  session   Session  @relation(fields: [sessionId], references: [id])
}

model Memory {
  id        String   @id @default(uuid())
  userId    String
  content   String
  embedding String   // JSON array of floats (SQLite fallback for pgvector)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

model Skill {
  id          String   @id @default(uuid())
  userId      String
  name        String   // 技能名称，如 "小红书爆款文案"
  description String   // 技能描述，用于大模型判断何时调用
  content     String   // 技能的 Prompt SOP 内容
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}